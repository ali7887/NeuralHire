{
  "name": "job-board-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Job Board SaaS built with Next.js 15, TypeScript, Drizzle ORM, and Vercel Postgres.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:ai": "tsx -r dotenv/config scripts/testAI.ts",
    "test:ai:connection": "tsx -r dotenv/config scripts/testConnectionAI.ts",
    "test:ai:summary": "tsx -r dotenv/config scripts/testJobSummary.ts",
    "test:ai:resume": "tsx -r dotenv/config scripts/testResumeAI.ts",
    "test:ai:match": "tsx -r dotenv/config scripts/testMatchAI.ts",
    "test:ai:ranking": "tsx -r dotenv/config scripts/testRankingAI.ts",
    "test:ai:recommend": "tsx -r dotenv/config scripts/testRecommendationAI.ts",
    "ai:test:embedding": "tsx -r dotenv/config scripts/testEmbedding.ts",
    "ai:test:env": "tsx -r dotenv/config scripts/testEnv.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed:admin": "ts-node --transpile-only scripts/seed.ts",
    "type-check": "tsc --noEmit",
    "// ---- Database ----": "",
    "check": "npm run type-check && npm run lint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "// ---- Vercel / CI ----": "",
    "vercel-build": "npm run lint && npm run type-check && npm run build"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "ai": "^5.0.72",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "https-proxy-agent": "^9.0.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.10"
  }
}